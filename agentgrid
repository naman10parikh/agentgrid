# ─── Self-update ───
cmd_update() {
    log "Checking for updates..."

    # Get latest version from GitHub
    local latest
    latest=$(curl -fsSL "https://raw.githubusercontent.com/naman10parikh/agentgrid/main/agentgrid" 2>/dev/null | grep '^VERSION=' | head -1 | cut -d'"' -f2)

    if [ -z "$latest" ]; then
        err "Couldn't check for updates (no internet?)"
        return 1
    fi

    if [ "$latest" = "$VERSION" ]; then
        log "${GREEN}Already on latest${NC} (v${VERSION})"
        return 0
    fi

    log "Update available: ${BOLD}v${VERSION} → v${latest}${NC}"
    echo -n "  Install? [Y/n] "
    read -r ans
    if [[ "$ans" =~ ^[Nn] ]]; then
        log "Skipped"
        return 0
    fi

    log "Updating..."
    local install_dir="${HOME}/.local/bin"
    curl -fsSL "https://raw.githubusercontent.com/naman10parikh/agentgrid/main/agentgrid" -o "${install_dir}/agentgrid"
    curl -fsSL "https://raw.githubusercontent.com/naman10parikh/agentgrid/main/pane-status.sh" -o "${install_dir}/agentgrid-pane-status"
    chmod +x "${install_dir}/agentgrid" "${install_dir}/agentgrid-pane-status"

    log "${GREEN}Updated to v${latest}${NC}"
    echo -e "  ${DIM}Restart your terminal for changes to take effect${NC}"
}

# ─── Detach (exit grid, keep it running) ───
cmd_detach() {
    if [ -n "${TMUX:-}" ]; then
        log "Detaching — grid keeps running in background"
        log "Reattach: ${CYAN}agentgrid start${NC}"
        tmux detach-client
    else
        log "Not in tmux — nothing to detach from"
    fi
}
cmd_kill_grid() { ensure_inside_tmux; local c=$(tmux list-panes | wc -l | tr -d ' '); while [ $(tmux list-panes | wc -l | tr -d ' ') -gt 1 ]; do tmux kill-pane -t ":.$(tmux list-panes -F '#{pane_index}' | tail -1)"; done; log "Cleared (was ${c} panes)"; }

cmd_status() {
    if [ -z "${TMUX:-}" ]; then
        ensure_tmux
        echo -e "\n${BOLD}⚡ agentgrid${NC} ${DIM}(outside tmux)${NC}\n"
        tmux list-sessions -F "  ${PURPLE}▸${NC} #{session_name}: #{session_windows} windows #{?session_attached,${GREEN}(attached)${NC},${DIM}(detached)${NC}}" 2>/dev/null || echo "  No sessions"
        echo -e "\n  Start: ${CYAN}agentgrid start${NC}\n"
        return
    fi
    echo -e "\n${BOLD}⚡ agentgrid status${NC}\n"
    local cd=0 cw=0 cr=0 ci=0
    while IFS= read -r line; do
        local ref=$(echo "$line" | cut -d'|' -f1) st=$(echo "$line" | cut -d'|' -f2) lb=$(echo "$line" | cut -d'|' -f3)
        [ -z "$lb" ] && lb="(unnamed)"
        case "$st" in
            done)        echo -e "  ${GREEN}✅ DONE${NC}     $lb ${DIM}[$ref]${NC}"; ((cd++)) ;;
            needs-input) echo -e "  ${YELLOW}⏳ WAITING${NC}  $lb ${DIM}[$ref]${NC}"; ((cw++)) ;;
            running)     echo -e "  ${BLUE}⚡ WORKING${NC}  $lb ${DIM}[$ref]${NC}"; ((cr++)) ;;
            *)           echo -e "  ${DIM}   IDLE${NC}     $lb ${DIM}[$ref]${NC}"; ((ci++)) ;;
        esac
    done < <(tmux list-panes -a -F '#{session_name}:#{window_index}.#{pane_index}|#{@pane_status}|#{@pane_label}' 2>/dev/null)
    echo -e "\n  ${GREEN}Done:${NC} $cd  ${YELLOW}Waiting:${NC} $cw  ${BLUE}Working:${NC} $cr  ${DIM}Idle:${NC} $ci\n"
}

cmd_version() { echo "agentgrid v${VERSION}"; }

