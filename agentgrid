# ─── Main ───
COMMAND="${1:-help}"; shift 2>/dev/null || true

case "$COMMAND" in
    start)       cmd_start "$@" ;;
    setup)       cmd_setup "$@" ;;
    grid)        cmd_grid "$@" ;;
    launch)      cmd_launch "$@" ;;
    preset)      cmd_preset "$@" ;;
    save)        cmd_save "$@" ;;
    restore)     cmd_restore "$@" ;;
    dashboard|dash) cmd_dashboard "$@" ;;
    swap)        cmd_swap "$@" ;;
    add)         cmd_add "$@" ;;
    detach|exit) cmd_detach ;;
    tips)        cmd_tips ;;
    terminal-setup|ts) cmd_terminal_setup "$@" ;;
    update)      cmd_update ;;
    agents)      cmd_agents "$@" ;;
    install)     cmd_install_agent "$@" ;;
    install-all) cmd_install_agent "all" ;;
    sound)       cmd_sound "$@" ;;
    name)        cmd_name "$@" ;;
    status)      cmd_status "$@" ;;
    broadcast)   cmd_broadcast "$@" ;;
    equalize)    cmd_equalize ;;
    kill)        cmd_kill_grid ;;
    version)     cmd_version ;;
    help|--help|-h) cmd_help ;;
    *x*)         cmd_grid "$COMMAND" "$@" ;;
    *)           err "Unknown: $COMMAND"; cmd_help; exit 1 ;;
esac
