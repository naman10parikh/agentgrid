#!/bin/bash
# agentgrid — Spawn a grid of AI coding agents in one command
# https://github.com/naman10parikh/agentgrid
# MIT License | v0.6.0

set -euo pipefail

VERSION="0.6.0"
CONFIG_DIR="${HOME}/.agentgrid"
CONFIG_FILE="${CONFIG_DIR}/config.json"
SOUNDS_DIR="${CONFIG_DIR}/sounds"
PRESETS_DIR="${CONFIG_DIR}/presets"
SESSIONS_DIR="${CONFIG_DIR}/sessions"
SESSION_NAME="${AGENTGRID_SESSION:-agentgrid}"

# ─── Colors (ANSI-C quoting so escape bytes work in heredocs + echo) ───
RED=$'\033[0;31m'; GREEN=$'\033[0;32m'; YELLOW=$'\033[0;33m'
BLUE=$'\033[0;34m'; PURPLE=$'\033[0;35m'; CYAN=$'\033[0;36m'
WHITE=$'\033[1;37m'; NC=$'\033[0m'; BOLD=$'\033[1m'; DIM=$'\033[2m'
BG_PURPLE=$'\033[45m'; BG_GREEN=$'\033[42m'; BG_YELLOW=$'\033[43m'
BG_BLUE=$'\033[44m'; BG_GRAY=$'\033[100m'

log() { echo -e "${PURPLE}[agentgrid]${NC} $1"; }
err() { echo -e "${RED}[agentgrid]${NC} $1" >&2; }

# ─── Config ───
get_config() {
    local key="$1" default="$2"
    [ -f "$CONFIG_FILE" ] || { echo "$default"; return; }
    python3 -c "
import json
try:
    with open('$CONFIG_FILE') as f: d = json.load(f)
    keys = '$key'.split('.')
    v = d
    for k in keys: v = v[k]
    print(v)
except: print('$default')
" 2>/dev/null
}

set_config() {
    local key="$1" value="$2"
    mkdir -p "$CONFIG_DIR"
    [ -f "$CONFIG_FILE" ] || echo '{}' > "$CONFIG_FILE"
    python3 -c "
import json
with open('$CONFIG_FILE') as f: d = json.load(f)
keys = '$key'.split('.')
ref = d
for k in keys[:-1]: ref = ref.setdefault(k, {})
ref[keys[-1]] = '$value'
with open('$CONFIG_FILE', 'w') as f: json.dump(d, f, indent=2)
"
}

# ─── Sound ───
play_sound() {
    local event="$1" sound_path
    case "$event" in
        done)     sound_path=$(get_config "sounds.done" "/System/Library/Sounds/Glass.aiff") ;;
        waiting)  sound_path=$(get_config "sounds.waiting" "/System/Library/Sounds/Tink.aiff") ;;
        subagent) sound_path=$(get_config "sounds.sub_agent" "/System/Library/Sounds/Purr.aiff") ;;
        *) return ;;
    esac
    [[ "$sound_path" == system:* ]] && sound_path="/System/Library/Sounds/${sound_path#system:}.aiff"
    [ -f "$sound_path" ] || return 0
    if command -v afplay &>/dev/null; then afplay "$sound_path" &
    elif command -v paplay &>/dev/null; then paplay "$sound_path" &
    fi
}

# ─── Agents ───
KNOWN_AGENTS="claude codex gemini aider opencode goose cline hermes copilot cursor"

get_agent_install_cmd() {
    case "$1" in
        claude)   echo "npm install -g @anthropic-ai/claude-code" ;;
        codex)    echo "npm install -g @openai/codex" ;;
        gemini)   echo "npm install -g @google/gemini-cli" ;;
        aider)    echo "pip install aider-chat" ;;
        opencode) echo "npm install -g opencode" ;;
        goose)    echo "brew install goose" ;;
        cline)    echo "npm install -g @anthropic-ai/cline" ;;
        hermes)   echo "npm install -g hermes-cli" ;;
        copilot)  echo "npm install -g @github/copilot" ;;
        cursor)   echo "brew install --cask cursor" ;;
        *)        echo "" ;;
    esac
}

check_agent_installed() { command -v "$1" &>/dev/null; }

# Map tmux process names to readable agent names
# tmux shows version numbers (2.1.76) or binary names, not the CLI alias
normalize_agent_name() {
    local raw="$1"
    case "$raw" in
        2.1.*|2.0.*|1.*)  echo "claude" ;;  # Claude Code shows version as process name
        codex-cli*)        echo "codex" ;;
        node)              echo "agent" ;;   # Many CLI tools run as node
        python*|python3*)  echo "aider" ;;   # Aider runs as python
        bash|zsh|fish)     echo "shell" ;;
        *)                 echo "$raw" ;;
    esac
}

# ─── Tmux ───
ensure_tmux() {
    command -v tmux &>/dev/null || {
        err "tmux required."
        case "$(uname -s)" in
            Darwin) echo "  Install: brew install tmux" ;;
            Linux)  echo "  Install: sudo apt install tmux" ;;
        esac
        exit 1
    }
}

ensure_inside_tmux() {
    [ -n "${TMUX:-}" ] && return 0
    ensure_tmux
    local session="${1:-$SESSION_NAME}"
    log "Launching tmux..."
    if tmux has-session -t "$session" 2>/dev/null; then
        exec tmux attach-session -t "$session"
    else
        exec tmux new-session -s "$session"
    fi
}

# ─── Visual TUI helpers ───
draw_box() {
    local width=$1 title="$2"
    local border=$(printf '─%.0s' $(seq 1 $((width-2))))
    echo -e "  ${DIM}┌${border}┐${NC}"
    if [ -n "$title" ]; then
        local pad=$(( (width - 2 - ${#title}) / 2 ))
        local lpad=$(printf ' %.0s' $(seq 1 $pad))
        echo -e "  ${DIM}│${NC}${lpad}${BOLD}${title}${NC}${lpad}${DIM}│${NC}"
        echo -e "  ${DIM}├${border}┤${NC}"
    fi
}

draw_box_end() {
    local width=$1
    local border=$(printf '─%.0s' $(seq 1 $((width-2))))
    echo -e "  ${DIM}└${border}┘${NC}"
}

draw_grid_preview() {
    local rows=$1 cols=$2 total=$3
    local cell_w=12
    local grid_w=$(( cols * (cell_w + 1) + 1 ))

    echo ""
    echo -e "  ${BOLD}Grid Preview: ${rows}x${cols}${NC}"
    echo ""

    local pane=1
    for ((r=1; r<=rows; r++)); do
        # Top border
        local line="  "
        for ((c=1; c<=cols; c++)); do
            if [ $c -eq 1 ]; then line+="┌"; else line+="┬"; fi
            line+=$(printf '─%.0s' $(seq 1 $cell_w))
        done
        line+="┐"
        echo -e "${DIM}${line}${NC}"

        # Content
        line="  "
        for ((c=1; c<=cols; c++)); do
            line+="${DIM}│${NC}"
            if [ $pane -le $total ]; then
                local label=$(printf "  Agent %-3s " "$pane")
                line+="${CYAN}${label}${NC}"
            else
                line+=$(printf ' %.0s' $(seq 1 $cell_w))
            fi
            pane=$((pane + 1))
        done
        line+="${DIM}│${NC}"
        echo -e "$line"
    done

    # Bottom border
    local line="  "
    for ((c=1; c<=cols; c++)); do
        if [ $c -eq 1 ]; then line+="└"; else line+="┴"; fi
        line+=$(printf '─%.0s' $(seq 1 $cell_w))
    done
    line+="┘"
    echo -e "${DIM}${line}${NC}"
    echo ""
}

# ─── Commands ───

cmd_start() {
    ensure_tmux
    if [ -n "${TMUX:-}" ]; then
        local session=$(tmux display-message -p '#{session_name}')
        log "${GREEN}Ready${NC} — tmux session: ${BOLD}${session}${NC}"
        echo ""
        echo -e "  ${CYAN}agentgrid 2x3 claude${NC}      Quick grid"
        echo -e "  ${CYAN}agentgrid setup${NC}            Visual wizard"
        echo -e "  ${CYAN}agentgrid launch <name>${NC}    Launch preset"
        echo -e "  ${CYAN}agentgrid preset list${NC}      See presets"
        echo ""
        return 0
    fi
    local session="${1:-$SESSION_NAME}"
    if tmux has-session -t "$session" 2>/dev/null; then
        log "Attaching to: ${BOLD}${session}${NC}"
        exec tmux attach-session -t "$session"
    else
        log "Creating: ${BOLD}${session}${NC}"
        exec tmux new-session -s "$session"
    fi
}

cmd_grid() {
    ensure_inside_tmux
    local grid="${1:-2x2}" command="${2:-}"

    local rows=${grid%%x*} cols=${grid##*x}

    [[ "$rows" =~ ^[0-9]+$ ]] && [[ "$cols" =~ ^[0-9]+$ ]] || { err "Format: agentgrid ROWSxCOLS [agent]"; exit 1; }
    [ "$rows" -ge 1 ] && [ "$rows" -le 10 ] && [ "$cols" -ge 1 ] && [ "$cols" -le 10 ] || { err "Max 10x10"; exit 1; }

    local agent_bin="${command%% *}"  # Extract binary name (before any flags)
    if [ -n "$agent_bin" ] && ! check_agent_installed "$agent_bin"; then
        log "${YELLOW}${agent_bin} not installed.${NC}"
        echo -n "  Install? [Y/n] "
        read -r ans
        if [[ ! "$ans" =~ ^[Nn] ]]; then
            local icmd=$(get_agent_install_cmd "$agent_bin")
            [ -n "$icmd" ] && { log "Installing..."; eval "$icmd" 2>&1; }
        fi
    fi

    local total=$((rows * cols))
    log "Creating ${BOLD}${rows}x${cols}${NC} grid (${total} panes)..."

    local window=$(tmux display-message -p '#{window_id}')

    # Create panes: split pane 1, re-tile after each split.
    for ((i=1; i<total; i++)); do
        tmux split-window -t "${window}.1" 2>/dev/null || \
        tmux split-window -v -t "${window}.1" 2>/dev/null || true
        tmux select-layout -t "$window" tiled 2>/dev/null
    done

    # Pick best layout for the pane count
    if [ "$total" -le 3 ] && [ "$cols" -ge "$rows" ]; then
        tmux select-layout -t "$window" even-horizontal 2>/dev/null
    elif [ "$total" -le 3 ] && [ "$rows" -gt "$cols" ]; then
        tmux select-layout -t "$window" even-vertical 2>/dev/null
    else
        tmux select-layout -t "$window" tiled 2>/dev/null
    fi
    local total_panes=$(tmux list-panes -t "$window" | wc -l | tr -d ' ')
    for ((p=1; p<=total_panes; p++)); do
        tmux set-option -p -t "${window}.${p}" @pane_label "Agent ${p}" 2>/dev/null
        tmux set-option -p -t "${window}.${p}" @pane_status "" 2>/dev/null
    done

    # Start agents in all panes
    if [ -n "$command" ]; then
        for ((p=1; p<=total_panes; p++)); do
            tmux send-keys -t "${window}.${p}" "$command" Enter 2>/dev/null
        done
        # If trust dialogs appear, user clicks Yes on each.
        # After the first Yes, Claude remembers the directory —
        # subsequent sessions in the same dir won't ask again.
    fi

    tmux select-pane -t "${window}.1"
    log "${GREEN}✅ ${rows}x${cols} = ${total_panes} panes${NC}"
    [ -n "$command" ] && log "Running: ${BOLD}${command}${NC}"
}

# ─── Visual Setup Wizard ───
cmd_setup() {
    ensure_inside_tmux

    # Detect agents
    local installed=""
    for agent in $KNOWN_AGENTS; do
        check_agent_installed "$agent" && installed="${installed}${agent} "
    done

    echo ""
    draw_box 60 "⚡ agentgrid setup"
    echo ""
    echo -e "  ${BOLD}Agents:${NC} ${GREEN}●${NC}=installed ${DIM}○${NC}=available"
    local agent_line="  "
    for agent in $KNOWN_AGENTS; do
        if check_agent_installed "$agent"; then
            agent_line+="${GREEN}●${NC}${BOLD}${agent}${NC} "
        else
            agent_line+="${DIM}○${agent}${NC} "
        fi
    done
    echo -e "$agent_line"
    echo ""
    draw_box_end 60

    # Step 1: Grid size
    echo ""
    echo -e "  ${BG_PURPLE}${WHITE} 1 ${NC} ${BOLD}Grid size?${NC} ${DIM}(e.g. 2x3 or just 6)${NC}"
    echo -n "  > "
    read -r grid_input

    local rows cols total
    if [[ "$grid_input" == *x* ]]; then
        rows=${grid_input%%x*}; cols=${grid_input##*x}; total=$((rows * cols))
    else
        total=$grid_input
        [[ "$total" =~ ^[0-9]+$ ]] || { err "Enter number or NxN"; return 1; }
        cols=$(python3 -c "import math; print(math.ceil(math.sqrt($total)))")
        rows=$(python3 -c "import math; print(math.ceil($total / math.ceil(math.sqrt($total))))")
    fi

    draw_grid_preview "$rows" "$cols" "$total"

    # Step 2: Default agent
    echo -e "  ${BG_BLUE}${WHITE} 2 ${NC} ${BOLD}Default agent for all panes?${NC} ${DIM}(or Enter for none)${NC}"
    echo -n "  > "
    read -r default_agent

    # Build pane config table (all defaults initially)
    local pane_names=()
    local pane_agents=()
    for ((i=1; i<=total; i++)); do
        pane_names+=("Pane $i")
        pane_agents+=("$default_agent")
    done

    # Step 3: Show table, let user edit specific panes
    echo ""
    echo -e "  ${BG_GREEN}${WHITE} 3 ${NC} ${BOLD}Configure panes${NC}"
    echo ""

    # Draw table
    local show_table=true
    while $show_table; do
        echo -e "  ${DIM}┌─────┬──────────────────┬──────────────────┐${NC}"
        echo -e "  ${DIM}│${NC} ${BOLD} #  ${NC}${DIM}│${NC} ${BOLD}Name             ${NC}${DIM}│${NC} ${BOLD}Agent            ${NC}${DIM}│${NC}"
        echo -e "  ${DIM}├─────┼──────────────────┼──────────────────┤${NC}"
        for ((i=0; i<total; i++)); do
            local idx=$((i+1))
            local name="${pane_names[$i]}"
            local agent="${pane_agents[$i]:-—}"
            [ -z "$agent" ] && agent="—"
            printf "  ${DIM}│${NC} %-3s ${DIM}│${NC} %-16s ${DIM}│${NC} %-16s ${DIM}│${NC}\n" "$idx" "$name" "$agent"
        done
        echo -e "  ${DIM}└─────┴──────────────────┴──────────────────┘${NC}"
        echo ""
        echo -e "  ${DIM}Enter pane # to edit, or press Enter to create grid${NC}"
        echo -n "  > "
        read -r edit_pane

        if [ -z "$edit_pane" ]; then
            show_table=false
        elif [[ "$edit_pane" =~ ^[0-9]+$ ]] && [ "$edit_pane" -ge 1 ] && [ "$edit_pane" -le "$total" ]; then
            local idx=$((edit_pane - 1))
            echo -n "    Name [${pane_names[$idx]}]: "
            read -r new_name
            [ -n "$new_name" ] && pane_names[$idx]="$new_name"
            echo -n "    Agent [${pane_agents[$idx]:-none}]: "
            read -r new_agent
            [ -n "$new_agent" ] && pane_agents[$idx]="$new_agent"
            echo ""
        else
            err "Enter a pane number (1-$total)"
        fi
    done

    # Step 4: Save as preset
    echo -e "  ${BG_GRAY}${WHITE} 4 ${NC} ${BOLD}Save as preset?${NC} ${DIM}(name or Enter to skip)${NC}"
    echo -n "  > "
    read -r preset_name

    # Auto-install missing agents
    local agents_to_install=""
    for ((i=0; i<total; i++)); do
        local agent="${pane_agents[$i]}"
        [ -n "$agent" ] && ! check_agent_installed "$agent" && agents_to_install="${agents_to_install} ${agent}"
    done
    agents_to_install=$(echo "$agents_to_install" | tr ' ' '\n' | sort -u | tr '\n' ' ' | xargs)
    if [ -n "$agents_to_install" ]; then
        echo ""
        echo -e "  ${YELLOW}Not installed:${NC} ${agents_to_install}"
        echo -n "  Install them? [Y/n] "
        read -r ans
        if [[ ! "$ans" =~ ^[Nn] ]]; then
            for agent in $agents_to_install; do
                local icmd=$(get_agent_install_cmd "$agent")
                [ -n "$icmd" ] && { log "Installing ${agent}..."; eval "$icmd" 2>&1 || true; }
            done
        fi
    fi

    # CREATE GRID INLINE (not as subprocess — this fixes the pane targeting bug)
    echo ""
    log "Creating ${BOLD}${rows}x${cols}${NC} grid..."

    local window=$(tmux display-message -p '#{window_id}')

    # Build the grid splits
    for ((r=1; r<rows; r++)); do
        local rem=$((rows - r + 1))
        tmux split-window -v -p $((100 - 100/rem)) -t "${window}.1"
    done
    for ((r=1; r<=rows; r++)); do
        local target=$r
        for ((c=1; c<cols; c++)); do
            local rem=$((cols - c + 1))
            tmux split-window -h -p $((100 - 100/rem)) -t "${window}.${target}"
            target=$((target + 1))
        done
    done
    tmux select-layout -t "$window" tiled

    # Apply names and start agents — using EXPLICIT window targeting
    local total_panes=$(tmux list-panes -t "$window" | wc -l | tr -d ' ')
    for ((i=0; i<total_panes && i<total; i++)); do
        local pane_idx=$((i + 1))
        local name="${pane_names[$i]:-Pane $pane_idx}"
        local agent="${pane_agents[$i]:-}"

        tmux set-option -p -t "${window}.${pane_idx}" @pane_label "$name" 2>/dev/null
        tmux set-option -p -t "${window}.${pane_idx}" @pane_status "" 2>/dev/null

        if [ -n "$agent" ]; then
            tmux send-keys -t "${window}.${pane_idx}" "$agent" Enter 2>/dev/null
        fi
    done

    tmux select-pane -t "${window}.1"

    # Save preset if requested
    if [ -n "$preset_name" ]; then
        mkdir -p "$PRESETS_DIR"
        python3 << PYEOF
import json
panes = []
for i in range(${total}):
    names = """${pane_names[*]}""".split("|||")
    agents = """${pane_agents[*]}""".split("|||")
    # Fallback to simple split
    all_names = "${pane_names[*]}".split()
    all_agents = "${pane_agents[*]}".split()
    name = all_names[i] if i < len(all_names) else f"Pane {i+1}"
    agent = all_agents[i] if i < len(all_agents) else ""
    panes.append({"name": name, "agent": agent})
with open("${PRESETS_DIR}/${preset_name}.json", "w") as f:
    json.dump({"description": "${rows}x${cols} grid", "panes": panes}, f, indent=2)
PYEOF
        log "Preset saved: ${BOLD}${preset_name}${NC}"
    fi

    echo ""
    log "${GREEN}✅ ${total} panes ready!${NC}"
}

# ─── Launch (presets only — no wizard) ───
cmd_launch() {
    ensure_inside_tmux
    local preset_name="${1:-}"

    if [ -z "$preset_name" ]; then
        # Show available presets instead of launching wizard
        echo -e "\n${BOLD}Usage:${NC} agentgrid launch <preset-name>\n"
        cmd_preset list
        echo -e "  ${DIM}Create new grid: agentgrid setup${NC}"
        echo -e "  ${DIM}Quick grid:      agentgrid 2x3 claude${NC}\n"
        return
    fi

    local preset_file="${PRESETS_DIR}/${preset_name}.json"
    [ -f "$preset_file" ] || { err "Preset '${preset_name}' not found."; cmd_preset list; exit 1; }

    log "Launching: ${BOLD}${preset_name}${NC}"
    python3 << PYEOF
import json, subprocess, time, math
with open("$preset_file") as f: preset = json.load(f)
panes = preset.get("panes", [])
total = len(panes)
cols = math.ceil(math.sqrt(total))
rows = math.ceil(total / cols)
subprocess.run(["agentgrid", "grid", f"{rows}x{cols}"], check=False)
time.sleep(1)
for i, pane in enumerate(panes):
    idx = i + 1
    name = pane.get("name", f"Agent {idx}")
    subprocess.run(["tmux", "set-option", "-p", "-t", f":.{idx}", "@pane_label", name], check=False)
    agent = pane.get("agent", "")
    if agent:
        subprocess.run(["tmux", "send-keys", "-t", f":.{idx}", agent, "Enter"], check=False)
print(f"  Launched {total} panes from '{preset_name}'")
PYEOF
}

# ─── Presets ───
cmd_preset() {
    local action="${1:-list}" name="${2:-}"
    case "$action" in
        list)
            echo -e "\n${BOLD}⚡ Presets${NC}\n"
            mkdir -p "$PRESETS_DIR"
            if ls "$PRESETS_DIR"/*.json &>/dev/null 2>&1; then
                for f in "$PRESETS_DIR"/*.json; do
                    local pname=$(basename "$f" .json)
                    local count=$(python3 -c "import json; print(len(json.load(open('$f')).get('panes',[])))" 2>/dev/null || echo "?")
                    local desc=$(python3 -c "import json; print(json.load(open('$f')).get('description',''))" 2>/dev/null || echo "")
                    echo -e "  ${PURPLE}▸${NC} ${BOLD}${pname}${NC} — ${count} panes ${DIM}${desc}${NC}"
                done
            else
                echo -e "  ${DIM}No presets. Create one with: agentgrid setup${NC}"
            fi
            echo "" ;;
        show)
            [ -z "$name" ] && { err "Usage: agentgrid preset show <name>"; return 1; }
            local f="${PRESETS_DIR}/${name}.json"
            [ -f "$f" ] || { err "Not found: $name"; return 1; }
            python3 -c "
import json
with open('$f') as f: p = json.load(f)
print(f'\n  ${name}: {p.get(\"description\",\"\")}')
print(f'  Panes: {len(p[\"panes\"])}\n')
for i, pane in enumerate(p['panes'], 1):
    print(f'  {i}. {pane[\"name\"]} -> {pane.get(\"agent\", \"(empty)\")}')
print()
" ;;
        delete)
            [ -z "$name" ] && { err "Usage: agentgrid preset delete <name>"; return 1; }
            rm -f "${PRESETS_DIR}/${name}.json" && log "Deleted: ${name}" ;;
        *) err "Usage: agentgrid preset [list|show|delete] <name>" ;;
    esac
}

# ─── Session save/restore ───
cmd_save() {
    ensure_inside_tmux
    local name="${1:-default}"
    mkdir -p "$SESSIONS_DIR"
    python3 << PYEOF
import json, subprocess, re, os
# Capture: index, label, running command, working directory, pane status
result = subprocess.run(["tmux", "list-panes", "-F",
    "#{pane_index}|#{@pane_label}|#{pane_current_command}|#{pane_current_path}|#{@pane_status}"],
    capture_output=True, text=True)

def normalize(cmd):
    """Map tmux process names to readable agent names"""
    if re.match(r'^\d+\.\d+\.\d+', cmd):  # Version number = Claude Code
        return "claude"
    if cmd.startswith("codex"): return "codex"
    if cmd in ("bash", "zsh", "fish"): return ""
    return cmd

panes = []
for line in result.stdout.strip().split('\n'):
    if not line: continue
    parts = line.split('|')
    if len(parts) >= 5:
        idx = int(parts[0])
        panes.append({
            "pane": idx,
            "label": parts[1],
            "command": normalize(parts[2]),
            "directory": parts[3],
            "status": parts[4]
        })
        # Capture pane buffer (what's visible on screen) for reference
        buf = subprocess.run(["tmux", "capture-pane", "-p", "-t", f":.{idx}"],
            capture_output=True, text=True)
        if buf.stdout.strip():
            buf_file = os.path.join("$SESSIONS_DIR", f"$name-pane-{idx}.txt")
            with open(buf_file, "w") as bf:
                bf.write(buf.stdout)

with open("$SESSIONS_DIR/$name.json", "w") as f:
    json.dump({"name": "$name", "panes": panes}, f, indent=2)
print(f"  Saved: $name ({len(panes)} panes)")
for p in panes:
    cmd = p["command"] or "shell"
    print(f"    Pane {p['pane']}: {p['label']} ({cmd})")
print(f"  Buffers saved to ~/.agentgrid/sessions/$name-pane-*.txt")
PYEOF
}

cmd_restore() {
    ensure_inside_tmux
    local name="" no_start=false

    # Parse args: name and --no-start flag
    for arg in "$@"; do
        case "$arg" in
            --no-start) no_start=true ;;
            *) [ -z "$name" ] && name="$arg" ;;
        esac
    done

    # If no name, list available sessions
    if [ -z "$name" ]; then
        echo -e "\n${BOLD}⚡ Saved Sessions${NC}\n"
        mkdir -p "$SESSIONS_DIR"
        if ls "$SESSIONS_DIR"/*.json &>/dev/null 2>&1; then
            for f in "$SESSIONS_DIR"/*.json; do
                local sname=$(basename "$f" .json)
                local count=$(python3 -c "import json; print(len(json.load(open('$f')).get('panes',[])))" 2>/dev/null || echo "?")
                local saved_at=$(stat -f "%Sm" -t "%Y-%m-%d %H:%M" "$f" 2>/dev/null || stat -c "%y" "$f" 2>/dev/null | cut -d. -f1 || echo "?")
                echo -e "  ${PURPLE}▸${NC} ${BOLD}${sname}${NC} — ${count} panes ${DIM}(saved: ${saved_at})${NC}"
            done
        else
            echo -e "  ${DIM}No saved sessions. Save one: agentgrid save my-grid${NC}"
        fi
        echo -e "\n  Restore: ${CYAN}agentgrid restore <name>${NC}"
        echo -e "  ${DIM}Layout only: agentgrid restore <name> --no-start${NC}\n"
        return
    fi

    local file="${SESSIONS_DIR}/${name}.json"
    [ -f "$file" ] || { err "No session: $name"; cmd_restore; exit 1; }

    log "Restoring: ${BOLD}${name}${NC}"
    $no_start && log "${DIM}--no-start: agents will not be restarted${NC}"

    # Read the saved session to get pane count
    local total
    total=$(python3 -c "import json; print(len(json.load(open('$file')).get('panes',[])))" 2>/dev/null)
    [ -z "$total" ] || [ "$total" -eq 0 ] && { err "Empty session file"; return 1; }

    local window=$(tmux display-message -p '#{window_id}')

    # Create panes using split+tile approach
    for ((i=1; i<total; i++)); do
        tmux split-window -t "${window}.1" 2>/dev/null || \
        tmux split-window -v -t "${window}.1" 2>/dev/null || true
        tmux select-layout -t "$window" tiled 2>/dev/null
    done
    # Smart layout: even-horizontal for <=3 panes, tiled for more
    if [ "$total" -le 3 ]; then
        tmux select-layout -t "$window" even-horizontal 2>/dev/null
    else
        tmux select-layout -t "$window" tiled 2>/dev/null
    fi
    sleep 0.5

    # Apply names, cd to directories, and restart saved commands
    local start_agents="$( $no_start && echo False || echo True )"
    python3 << PYEOF
import json, subprocess, time

with open("$file") as f: session = json.load(f)
panes = session.get("panes", [])
total = len(panes)
start_agents = $start_agents

started = []
for p in panes:
    idx = p.get("pane", 0)
    if idx < 1 or idx > total: continue
    label = p.get("label", f"Pane {idx}")
    directory = p.get("directory", "")
    command = p.get("command", "")
    target = "$window" + f".{idx}"

    # Set pane metadata
    subprocess.run(["tmux", "set-option", "-p", "-t", target, "@pane_label", label], check=False)
    subprocess.run(["tmux", "set-option", "-p", "-t", target, "@pane_status", ""], check=False)

    # cd to saved directory
    if directory:
        subprocess.run(["tmux", "send-keys", "-t", target, f"cd {directory}", "Enter"], check=False)

    # Restart saved command (unless --no-start)
    if start_agents and command:
        time.sleep(0.3)  # Let cd complete
        if command == "claude":
            subprocess.run(["tmux", "send-keys", "-t", target, "claude --continue", "Enter"], check=False)
        else:
            subprocess.run(["tmux", "send-keys", "-t", target, command, "Enter"], check=False)
        started.append(f"    Pane {idx}: {label} -> {command}")

subprocess.run(["tmux", "select-pane", "-t", "$window" + ".1"])
print(f"  Restored {total} panes")
if started:
    print(f"  Restarted {len(started)} agents:")
    for s in started:
        print(s)
    print(f"  (Claude panes resume last conversation via --continue)")
else:
    print(f"  Layout + names only (no agents started)")
    print(f"  Start agents: agentgrid broadcast claude")
PYEOF
}

# ─── Agents ───
cmd_agents() {
    echo -e "\n${BOLD}⚡ CLI Agents${NC}\n"
    for agent in $KNOWN_AGENTS; do
        if check_agent_installed "$agent"; then
            local ver=$($agent --version 2>/dev/null | head -1 || echo "installed")
            echo -e "  ${GREEN}●${NC} ${BOLD}${agent}${NC} ${DIM}${ver}${NC}"
        else
            echo -e "  ${RED}○${NC} ${agent} ${DIM}$(get_agent_install_cmd "$agent")${NC}"
        fi
    done
    echo -e "\n  ${CYAN}agentgrid install <agent>${NC}   Install one"
    echo -e "  ${CYAN}agentgrid install-all${NC}       Install all missing"
    echo -e "  ${DIM}Any command works as an agent — not limited to this list${NC}\n"
}

cmd_install_agent() {
    local agent="${1:-}"
    [ -z "$agent" ] && { cmd_agents; return; }
    if [ "$agent" = "all" ]; then
        for a in $KNOWN_AGENTS; do
            check_agent_installed "$a" || {
                local cmd=$(get_agent_install_cmd "$a")
                [ -n "$cmd" ] && { log "Installing ${a}..."; eval "$cmd" 2>&1 || true; }
            }
        done
        log "${GREEN}Done${NC}"; return
    fi
    check_agent_installed "$agent" && { log "${agent} already installed"; return; }
    local cmd=$(get_agent_install_cmd "$agent")
    [ -z "$cmd" ] && { err "Unknown: $agent"; return 1; }
    log "Installing ${BOLD}${agent}${NC}..."; eval "$cmd"; log "${GREEN}✓ ${agent}${NC}"
}

# ─── Sound ───
cmd_sound() {
    local event="${1:-}" file="${2:-}"
    case "$event" in
        off) set_config "sounds.done" ""; set_config "sounds.waiting" ""; set_config "sounds.sub_agent" ""; log "Sounds off" ;;
        test) log "Testing..."; echo -e "  ${GREEN}Done:${NC}"; play_sound "done"; sleep 1; echo -e "  ${YELLOW}Waiting:${NC}"; play_sound "waiting"; sleep 1; echo -e "  ${BLUE}Sub-agent:${NC}"; play_sound "subagent"; sleep 1; log "Done" ;;
        ""|list)
            echo -e "\n${BOLD}Sounds${NC}\n"
            echo -e "  ${GREEN}done:${NC}     $(get_config 'sounds.done' '/System/Library/Sounds/Glass.aiff')"
            echo -e "  ${YELLOW}waiting:${NC}  $(get_config 'sounds.waiting' '/System/Library/Sounds/Tink.aiff')"
            echo -e "  ${BLUE}subagent:${NC} $(get_config 'sounds.sub_agent' '/System/Library/Sounds/Purr.aiff')"
            echo -e "\n  ${CYAN}agentgrid sound done ~/Music/tada.mp3${NC}"
            echo -e "  ${DIM}macOS: Glass Hero Tink Purr Pop Ping Submarine Morse Blow${NC}\n" ;;
        *)
            [ -z "$file" ] && { err "Usage: agentgrid sound <done|waiting|subagent> <file>"; return 1; }
            local key; case "$event" in done) key="sounds.done" ;; waiting) key="sounds.waiting" ;; subagent|sub_agent) key="sounds.sub_agent" ;; *) err "Events: done, waiting, subagent"; return 1 ;; esac
            if [[ "$file" != system:* ]] && [ -f "$file" ]; then
                mkdir -p "$SOUNDS_DIR"; cp "$file" "${SOUNDS_DIR}/$(basename "$file")"; set_config "$key" "${SOUNDS_DIR}/$(basename "$file")"
            else set_config "$key" "$file"; fi
            log "Set ${BOLD}${event}${NC} → ${file}"; play_sound "$event" ;;
    esac
}

# ─── Dashboard (grid map + controls) ───
cmd_dashboard() {
    ensure_inside_tmux

    local mode="${1:-}"
    local session=$(tmux display-message -p '#{session_name}')
    local total=$(tmux list-panes | wc -l | tr -d ' ')

    if [ "$mode" = "live" ] || [ "$mode" = "watch" ]; then
        # Live mode — refreshes every 2s
        echo -e "${BOLD}⚡ agentgrid dashboard${NC} ${DIM}(live — Ctrl+C to exit)${NC}"
        echo ""
        while true; do
            tput cup 2 0 2>/dev/null; tput ed 2>/dev/null
            _draw_dashboard_table
            sleep 2
        done
    else
        # Default: static snapshot + controls
        echo ""
        echo -e "  ${BOLD}⚡ agentgrid dashboard${NC}"
        echo -e "  ${DIM}Session: ${session} · ${total} panes · $(date '+%H:%M')${NC}"
        echo ""
        _draw_dashboard_table
        echo -e "  ${BOLD}Quick actions:${NC}"
        echo -e "    ${CYAN}agentgrid add${NC}             Add a pane"
        echo -e "    ${CYAN}agentgrid name <n>${NC}        Name current pane"
        echo -e "    ${CYAN}agentgrid swap up/down${NC}    Move panes"
        echo -e "    ${CYAN}agentgrid equalize${NC}        Even sizes"
        echo -e "    ${CYAN}agentgrid save <n>${NC}        Save this grid"
        echo -e "    ${CYAN}agentgrid dashboard live${NC}  Auto-refreshing view"
        echo ""
        echo -e "  ${BOLD}Mouse:${NC} ${DIM}Drag pane borders to resize · Click to switch panes${NC}"
        echo -e "  ${BOLD}Keys:${NC}  ${DIM}Ctrl+A z zoom · Ctrl+A Space cycle layout · Ctrl+A { } swap${NC}"
        echo ""
    fi
}

_draw_dashboard_table() {
    echo -e "  ${DIM}┌─────┬──────────────────┬──────────────────┬────────────┐${NC}"
    echo -e "  ${DIM}│${NC} ${BOLD} #  ${NC}${DIM}│${NC} ${BOLD}Name             ${NC}${DIM}│${NC} ${BOLD}Agent            ${NC}${DIM}│${NC} ${BOLD}Status     ${NC}${DIM}│${NC}"
    echo -e "  ${DIM}├─────┼──────────────────┼──────────────────┼────────────┤${NC}"

    while IFS= read -r line; do
        local idx=$(echo "$line" | cut -d'|' -f1)
        local label=$(echo "$line" | cut -d'|' -f2)
        local raw_cmd=$(echo "$line" | cut -d'|' -f3)
        local status=$(echo "$line" | cut -d'|' -f4)
        [ -z "$label" ] && label="Pane $idx"
        local cmd=$(normalize_agent_name "${raw_cmd:-—}")

        local sd
        case "$status" in
            done)        sd="${GREEN}✅ DONE  ${NC}" ;;
            needs-input) sd="${YELLOW}⏳ WAIT  ${NC}" ;;
            running)     sd="${BLUE}⚡ RUN   ${NC}" ;;
            *)           sd="${DIM}   idle  ${NC}" ;;
        esac

        printf "  ${DIM}│${NC} %-3s ${DIM}│${NC} %-16s ${DIM}│${NC} %-16s ${DIM}│${NC} %b${DIM}│${NC}\n" \
            "$idx" "${label:0:16}" "${cmd:0:16}" "$sd"
    done < <(tmux list-panes -F '#{pane_index}|#{@pane_label}|#{pane_current_command}|#{@pane_status}' 2>/dev/null)

    echo -e "  ${DIM}└─────┴──────────────────┴──────────────────┴────────────┘${NC}"
    echo ""
}

# ─── Swap panes ───
cmd_swap() {
    ensure_inside_tmux
    local direction="${1:-}"
    case "$direction" in
        up|prev)    tmux swap-pane -U; log "Swapped up" ;;
        down|next)  tmux swap-pane -D; log "Swapped down" ;;
        "")
            echo -e "\n${BOLD}Swap & arrange panes:${NC}"
            echo -e "  ${CYAN}agentgrid swap up${NC}     Swap with previous pane"
            echo -e "  ${CYAN}agentgrid swap down${NC}   Swap with next pane"
            echo ""
            echo -e "  ${BOLD}Keyboard shortcuts:${NC}"
            echo -e "  ${DIM}Ctrl+A {${NC}          Swap up"
            echo -e "  ${DIM}Ctrl+A }${NC}          Swap down"
            echo -e "  ${DIM}Ctrl+A Ctrl+O${NC}     Rotate all panes"
            echo -e "  ${DIM}Ctrl+A Space${NC}      Cycle layouts (tiled → horizontal → vertical → ...)"
            echo -e "  ${DIM}Ctrl+A z${NC}          Zoom pane (fullscreen toggle)"
            echo "" ;;
        *) err "Usage: agentgrid swap [up|down]" ;;
    esac
}

# ─── Add pane to existing grid ───
cmd_add() {
    ensure_inside_tmux
    local direction="${1:-right}"
    local agent="${2:-}"

    case "$direction" in
        right|r)  tmux split-window -h -c "#{pane_current_path}" ;;
        down|d)   tmux split-window -v -c "#{pane_current_path}" ;;
        *)        tmux split-window -h -c "#{pane_current_path}" ;;
    esac

    # Name it
    local pane_count=$(tmux list-panes | wc -l | tr -d ' ')
    tmux set-option -p @pane_label "Pane ${pane_count}" 2>/dev/null
    tmux set-option -p @pane_status "" 2>/dev/null

    # Optionally name it
    if [ -n "$agent" ] && [ "$agent" != "right" ] && [ "$agent" != "down" ]; then
        # If second arg looks like an agent, start it
        if check_agent_installed "$agent" || get_agent_install_cmd "$agent" | grep -q .; then
            tmux send-keys "$agent" Enter 2>/dev/null
            log "Added pane → ${BOLD}${agent}${NC}"
        else
            # Treat as a name
            tmux set-option -p @pane_label "$agent" 2>/dev/null
            log "Added pane: ${BOLD}${agent}${NC}"
        fi
    else
        log "Added pane (${direction})"
    fi

    # Re-equalize
    tmux select-layout tiled 2>/dev/null
}

# ─── Utility ───
cmd_name() { ensure_inside_tmux; [ -z "${1:-}" ] && { err "Usage: agentgrid name <name>"; return 1; }; tmux set-option -p @pane_label "$1"; log "Named: ${BOLD}${1}${NC}"; }
cmd_broadcast() { ensure_inside_tmux; [ -z "${1:-}" ] && { err "Usage: agentgrid broadcast <text>"; return 1; }; local w=$(tmux display-message -p '#{window_id}') t="$*" c=0; for p in $(tmux list-panes -t "$w" -F '#{pane_id}'); do tmux send-keys -t "$p" "$t" Enter 2>/dev/null; ((c++)); done; log "Broadcast to ${BOLD}${c}${NC} panes"; }
cmd_equalize() { ensure_inside_tmux; tmux select-layout tiled; log "Equalized"; }

# ─── Setup helpers (execute, not just tips) ───
cmd_terminal_setup() {
    ensure_inside_tmux
    local scope="${1:-all}"

    echo ""
    echo -e "  ${BOLD}⚡ Terminal setup${NC}"
    echo ""

    if [ "$scope" = "all" ]; then
        # Send /terminal-setup to ALL panes running Claude
        local count=0
        while IFS= read -r line; do
            local pane_id=$(echo "$line" | cut -d'|' -f1)
            local cmd=$(echo "$line" | cut -d'|' -f2)
            local normalized=$(normalize_agent_name "$cmd")
            if [ "$normalized" = "claude" ]; then
                tmux send-keys -t "$pane_id" "/terminal-setup" Enter 2>/dev/null
                count=$((count + 1))
            fi
        done < <(tmux list-panes -F '#{pane_id}|#{pane_current_command}' 2>/dev/null)

        if [ "$count" -gt 0 ]; then
            log "Sent ${CYAN}/terminal-setup${NC} to ${BOLD}${count}${NC} Claude panes"
            echo -e "  ${GREEN}✓${NC} Option+Enter = new line in all Claude panes"
        else
            log "${YELLOW}No Claude panes found${NC}"
            echo -e "  Start Claude first: ${CYAN}agentgrid 2x2 claude${NC}"
        fi
    else
        # Just current pane
        tmux send-keys "/terminal-setup" Enter 2>/dev/null
        log "Sent ${CYAN}/terminal-setup${NC} to current pane"
    fi
    echo ""
}

cmd_tips() {
    echo ""
    echo -e "  ${BOLD}⚡ agentgrid tips${NC}"
    echo ""
    echo -e "  ${BOLD}Multi-line input:${NC}"
    echo -e "    Ghostty, iTerm2, Kitty, WezTerm: ${BOLD}Shift+Enter${NC} for new line"
    echo -e "    Any terminal: type ${BOLD}\\${NC} then Enter for new line"
