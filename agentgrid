    echo -e "    Click ${BOLD}Yes${NC} on each pane — takes a few seconds."
    echo -e "    After that, the directory is trusted permanently."
    echo -e "    ${DIM}Tip: cd into your project BEFORE running agentgrid${NC}"
    echo ""
    echo -e "  ${BOLD}Voice input:${NC}"
    echo -e "    Claude Code: long-press Spacebar"
    echo -e "    macOS dictation: press Fn key twice"
    echo ""
    echo -e "  ${BOLD}Files & images:${NC}"
    echo -e "    Drag & drop files into any pane"
